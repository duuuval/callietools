{
  "crons": [
    {
      "path": "/api/snapshot",
      "schedule": "0 6 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/ics/:id.ics",
      "destination": "/api/ics/:id.ics"
    },
    {
      "source": "/ics/:id",
      "destination": "/api/ics/:id"
    },
    {
      "source": "/:id",
      "destination": "/calendar/:id"
    }
  ]
}
